{
  "manifest_version": 3,
  "name": "ChatGPT HTML Extractor",
  "version": "1.0",
  "description": "Background extractor for ChatGPT share links",
  "permissions": [
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://chat.deepseek.com/*",
    "https://grok.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/share/*",
        "https://chatgpt.com/c/*"
      ],
      "js": ["chatgpt-inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://chatgpt.com/share/*",
        "https://chatgpt.com/c/*"
      ],
      "js": ["chatgpt-content.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.run.app/*",
        "https://*.onrender.com/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["content-inject.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://*.run.app/*",
      "https://*.onrender.com/*",
      "http://localhost:3000/*",
      "http://127.0.0.1:3000/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  }
}
